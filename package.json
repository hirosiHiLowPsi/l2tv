{
  "name": "lr2ir-table-lamp-viewer",
  "version": "2.1.0",
  "private": true,
  "license": "MIT",
  "main": "electron-main.js",
  "description": "L2TV (LR2 Table Viewer)",
  "author": "HiLowPsi",
  "executableName": "L2TV",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist:win": "node scripts/build-win-zip.js --format=7z",
    "dist:win:7z": "node scripts/build-win-zip.js --format=7z",
    "dist:win:force-pretest": "node scripts/build-win-zip.js --suffix=force-rate-pretest --format=7z",
    "dist:radar": "node notes-radar-app/scripts/build-win-zip.js",
    "force:constants:score-oriented": "node scripts/apply-score-oriented-force-constants.js",
    "test:force": "node --test scripts/force-rating.test.js",
    "test": "node --test scripts/force-rating.test.js scripts/data-import.test.js scripts/security-config.test.js scripts/ui-smoke.test.js scripts/electron-main-smoke.test.js"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "7zip-bin": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.0"
  },
  "build": {
    "appId": "com.hilowpsi.l2tv",
    "productName": "L2TV",
    "copyright": "Copyright 2026 HiLowPsi",
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "database-worker.js",
      "build/icon.ico",
      "public/**/*",
      "!public/assets/force-rating-badges.png",
      "!public/assets/force-rank-badges/rank_badges_sheet.png",
      "!public/assets/force-rank-badges/rank_badges.json",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "readme.txt",
        "to": "readme.txt"
      },
      {
        "from": "readme_en.txt",
        "to": "readme_en.txt"
      },
      {
        "from": "README.md",
        "to": "README.md"
      },
      {
        "from": "FORCE_RATE_SPEC.md",
        "to": "FORCE_RATE_SPEC.md"
      },
      {
        "from": "更新履歴.txt",
        "to": "更新履歴.txt"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "SECURITY.md",
        "to": "SECURITY.md"
      }
    ],
    "afterPack": "scripts/apply-electron-fuses.js",
    "electronLanguages": [
      "ja",
      "en-US"
    ],
    "win": {
      "icon": "build/icon.ico"
    }
  },
  "allowScripts": {
    "electron@43.1.0": true
  }
}
