{
  "name": "lr2ir-table-lamp-viewer",
  "version": "2.1.0",
  "private": true,
  "license": "MIT",
  "main": "electron-main.js",
  "description": "L2TV (LR2 Table Viewer)",
  "author": "HiLowPsi",
  "executableName": "L2TV",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist:win": "node scripts/build-win-zip.js --format=7z",
    "dist:win:zip": "node scripts/build-win-zip.js",
    "dist:win:7z": "node scripts/build-win-zip.js --format=7z",
    "dist:win:force-pretest": "node scripts/build-win-zip.js --suffix=force-rate-pretest",
    "dist:win:force-pretest:7z": "node scripts/build-win-zip.js --suffix=force-rate-pretest --format=7z",
    "dist:radar": "node notes-radar-app/scripts/build-win-zip.js",
    "force:constants:score-oriented": "node scripts/apply-score-oriented-force-constants.js",
    "test:force": "node --test scripts/force-rating.test.js",
    "test": "node --test scripts/force-rating.test.js scripts/data-import.test.js",
    "dist:win:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.0"
  },
  "build": {
    "appId": "com.hilowpsi.l2tv",
    "productName": "L2TV",
    "copyright": "Copyright 2026 HiLowPsi",
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "build/icon.ico",
      "public/**/*",
      "!public/assets/force-rating-badges.png",
      "!public/assets/force-rank-badges/rank_badges_sheet.png",
      "!public/assets/force-rank-badges/rank_badges.json",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "readme.txt",
        "to": "readme.txt"
      },
      {
        "from": "readme_en.txt",
        "to": "readme_en.txt"
      },
      {
        "from": "README.md",
        "to": "README.md"
      },
      {
        "from": "FORCE_RATE_SPEC.md",
        "to": "FORCE_RATE_SPEC.md"
      },
      {
        "from": "更新履歴.txt",
        "to": "更新履歴.txt"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "zip"
      ],
      "artifactName": "${productName}-${version}-win-x64.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    }
  }
}
