{
  "name": "lr2ir-table-lamp-viewer",
  "version": "1.0.2",
  "private": true,
  "main": "electron-main.js",
  "description": "L2TV (LR2 Table Viewer)",
  "author": "HiLowPsi",
  "executableName": "L2TV",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.0"
  },
  "build": {
    "appId": "com.hilowpsi.l2tv",
    "productName": "L2TV",
    "copyright": "Copyright 2026 HiLowPsi",
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "public/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "readme.txt",
        "to": "readme.txt"
      },
      {
        "from": "readme_en.txt",
        "to": "readme_en.txt"
      },
      {
        "from": "更新履歴.txt",
        "to": "更新履歴.txt"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    }
  }
}
